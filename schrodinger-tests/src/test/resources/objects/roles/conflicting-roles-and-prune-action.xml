<objects xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
         xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
         xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3">

    <!-- Role A: name only + assignment of the switch role -->
    <role oid="0a000000-0000-4000-8000-000000000a01">
        <name>TEST SoD prune - Role A</name>
        <assignment>
            <targetRef oid="0c000000-0000-4000-8000-000000000c03" type="RoleType"/>
        </assignment>
    </role>

    <!-- Role B: name only + assignment of the switch role -->
    <role oid="0b000000-0000-4000-8000-000000000b02">
        <name>TEST SoD prune - Role B</name>
        <assignment>
            <targetRef oid="0c000000-0000-4000-8000-000000000c03" type="RoleType"/>
        </assignment>
    </role>

    <!-- Switch role (PS): exclusion + prune for both member roles -->
    <role oid="0c000000-0000-4000-8000-000000000c03">
        <name>PS-TEST-SOD-PRUNE</name>
        <inducement id="1">
            <policyRule>
                <name>Exclusion: TEST SoD prune - Role A</name>
                <policyConstraints>
                    <exclusion>
                        <name>Exclusion: TEST SoD prune - Role A</name>
                        <targetRef oid="0a000000-0000-4000-8000-000000000a01"
                                   relation="org:default" type="RoleType"/>
                    </exclusion>
                </policyConstraints>
                <policyActions>
                    <prune/>
                </policyActions>
            </policyRule>
        </inducement>
        <inducement id="2">
            <policyRule>
                <name>Exclusion: TEST SoD prune - Role B</name>
                <policyConstraints>
                    <exclusion>
                        <name>Exclusion: TEST SoD prune - Role B</name>
                        <targetRef oid="0b000000-0000-4000-8000-000000000b02"
                                   relation="org:default" type="RoleType"/>
                    </exclusion>
                </policyConstraints>
                <policyActions>
                    <prune/>
                </policyActions>
            </policyRule>
        </inducement>
    </role>

</objects>
