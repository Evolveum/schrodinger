    <authorization>
        <name>managers-users-search</name>
        <action>http://midpoint.evolveum.com/xml/ns/public/security/authorization-model-3#read</action>
        <description>
            Moji nadrizeni podle organizacni jednotky. Hledame nadrizene podle moji parentOrgRef.
        </description>
        <object>
            <type>UserType</type>
            <c:filter>
                <q:ref>
                    <q:path>parentOrgRef</q:path>
                    <expression>
                        <script>
                            <code><![CDATA[
                                import com.evolveum.midpoint.xml.ns._public.common.common_3.OrgType
                                import com.evolveum.midpoint.xml.ns._public.common.common_3.ObjectReferenceType
                                import com.evolveum.midpoint.schema.constants.SchemaConstants

                                def createManagerOrgRef(orgOid) {
                                    ObjectReferenceType ort = new ObjectReferenceType()
                                    ort?.relation = SchemaConstants.ORG_MANAGER
                                    ort.setOid(orgOid)
                                    ort.setType(OrgType.COMPLEX_TYPE)

                                    return ort
                                }

                                managerRefs = []
                                subject?.parentOrgRef?.each {
                                    if (it?.relation?.equals(SchemaConstants.ORG_DEFAULT)) {    // pouze organizace, kde jsem beznym clenem
                                        managerRefs?.add(createManagerOrgRef(it?.oid))
                                    }
                                }
                                return managerRefs
                                ]]></code>
                        </script>
                    </expression>
                </q:ref>
            </c:filter>
        </object>
    </authorization>

    <authorization>
        <name>role-owner-modify-role-assignments-thresholds-request</name>
        <description>Authorization that allow role owner modification of roleAssignemnts and roleAssignmentThreshold
            atttributes
        </description>
        <action>http://midpoint.evolveum.com/xml/ns/public/security/authorization-model-3#modify</action>
        <action>http://midpoint.evolveum.com/xml/ns/public/security/authorization-model-3#add</action>
        <phase>request</phase>
        <object>
            <type>RoleType</type>
            <filter>
                <q:text><![CDATA[. inOid ```
                import com.evolveum.midpoint.xml.ns._public.common.common_3.RoleType
                import com.evolveum.midpoint.schema.constants.SchemaConstants


                def assignments = midpoint.principal.focus.getAssignment()

                def roleOwnerOids =
                    assignments.findAll { a ->
                        a.targetRef?.type == RoleType.COMPLEX_TYPE &&
                        a.targetRef?.relation == SchemaConstants.ORG_OWNER
                    }.collect { a ->
                        a.targetRef.oid
                    }

                return roleOwnerOids
                    ```]]></q:text>
            </filter>
        </object>
    </authorization>

